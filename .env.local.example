# Solar BOS - Environment Variables Template
# ==========================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local, .env.production, or .env.vercel to git
#
# To generate encryption keys: openssl rand -hex 32

# ============================================
# Supabase (Database & Auth)
# ============================================
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_PASSWORD=your-postgres-password

# ============================================
# Trigger.dev (Background Jobs for SMS/Email)
# ============================================
# Get these from: Trigger.dev Dashboard → Project Settings
TRIGGER_API_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxxx
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxxx

# ============================================
# Communications - Email (SendGrid)
# ============================================
# Get from: SendGrid Dashboard → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Company Name

# ============================================
# Communications - SMS & WhatsApp (Twilio)
# ============================================
# Get from: Twilio Console → Account → API Keys & Tokens
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Google APIs (Maps & Solar)
# ============================================
# Get from: Google Cloud Console → APIs & Services → Credentials
# Maps API: Used for embedded maps in BOS (client-side)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Solar API: Used for roof solar analysis (server-side)
GOOGLE_SOLAR_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SOLAR_BASE_URL=https://solar.googleapis.com/v1

# ============================================
# UK Ordnance Survey (Address Lookup)
# ============================================
# Get from: https://osdatahub.os.uk (create project + enable OS Places API)
OS_PLACES_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
OS_PLACES_BASE_URL=https://api.os.uk/search/places/v1

# ============================================
# Security & Encryption
# ============================================
# Generate with: openssl rand -hex 32
# IMPORTANT: Use DIFFERENT keys for dev, staging, and production
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Platform Configuration
# ============================================
# Set to your Vercel deployment URL (or localhost for dev)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Auto-generated by Vercel (do not set manually)
# VERCEL_OIDC_TOKEN=auto-generated

# ============================================
# External Services (Optional)
# ============================================
# OpenSolar Integration
# OPENSOLAR_USERNAME=your-username
# OPENSOLAR_PASSWORD=your-password

# GetAddress.io (Alternative UK address lookup)
# GETADDRESS_API_KEY=your-getaddress-key
# GOOGLE_MAPS_API_KEY=your-google-maps-key (legacy, use NEXT_PUBLIC_GOOGLE_MAPS_KEY)

# ============================================
# Development & Monitoring (Optional)
# ============================================
# Sentry Error Tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Portal Debug Logging (set to 'true' to enable verbose logs)
# DEBUG_PORTAL=false
